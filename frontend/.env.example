VITE_API_URL=http://localhost:8080/api

# Public OIDC values (these are safe to expose in browser bundles)
VITE_OIDC_AUTHORITY=https://your-tenant.auth0.com
VITE_OIDC_CLIENT_ID=your_spa_client_id
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_AUTHORIZATION_ENDPOINT=https://your-tenant.auth0.com/authorize
VITE_OIDC_TOKEN_ENDPOINT=https://your-tenant.auth0.com/oauth/token
VITE_OIDC_SCOPE=openid profile email

# Auth0 logout configuration (REQUIRED for proper session invalidation)
# Without these, logout clears local state but Auth0 session remains active
VITE_OIDC_LOGOUT_ENDPOINT=https://your-tenant.auth0.com/v2/logout
VITE_OIDC_LOGOUT_RETURN_TO=http://localhost:5173/login
# Set to true to logout from identity providers (Google, LinkedIn, Microsoft, etc) as well
VITE_OIDC_LOGOUT_FEDERATED=true
# Optional: force a specific org at Auth0 authorize time
# VITE_OIDC_ORGANIZATION=org_123456
