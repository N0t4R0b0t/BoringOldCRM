### ========================================
### 7. TEST TENANT SELECTION LOGIN FLOW
### ========================================
### NOTE: Run this after setting up multi-tenant memberships
### When a user with multiple tenant memberships logs in without an OIDC org claim,
### the response will have requiresTenantSelection: true with availableTenants list

### Login Demo User (Multiple Tenants) - This should return tenant selection
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{demoEmail}}",
  "password": "{{demoPassword}}"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });

    if (response.body.requiresTenantSelection) {
        client.log("✓ TENANT SELECTION REQUIRED");
        client.log("  - Available tenants: " + response.body.availableTenants.length);
        response.body.availableTenants.forEach((t, idx) => {
            client.log("  [" + (idx + 1) + "] " + t.name + " (ID: " + t.id + ", Role: " + t.role + ")");
        });
        // Store the selection token for switching
        client.global.set("selectionAccessToken", response.body.accessToken);
        client.log("✓ Stored selection token for tenant switching");
    } else {
        client.log("⚠ Tenant selection NOT required (user has only one tenant)");
    }
%}

---

### ========================================
### 8. SWITCH TO DIFFERENT TENANT
### ========================================
### After login returns requiresTenantSelection: true,
### use the selection token to call switchTenant

### Switch to Tenant 1
POST {{baseUrl}}/auth/switch-tenant
Authorization: Bearer {{selectionAccessToken}}
Content-Type: application/json

{
  "tenantId": {{tenantId1}}
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has new accessToken", function() {
        client.assert(response.body.accessToken !== undefined, "Should have new accessToken");
    });
    client.global.set("tenant1AccessToken", response.body.accessToken);
    client.log("✓ Switched to Tenant 1 (Acme Corp)");
    client.log("  - Current Tenant ID: " + response.body.currentTenantId);
    client.log("  - Current Role: " + response.body.currentRole);
    client.log("  - New Access Token: " + response.body.accessToken.substring(0, 20) + "...");
%}

### Switch to Tenant 2
POST {{baseUrl}}/auth/switch-tenant
Authorization: Bearer {{selectionAccessToken}}
Content-Type: application/json

{
  "tenantId": {{tenantId2}}
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.global.set("tenant2AccessToken", response.body.accessToken);
    client.log("✓ Switched to Tenant 2 (TechStart Inc)");
    client.log("  - Current Tenant ID: " + response.body.currentTenantId);
    client.log("  - Current Role: " + response.body.currentRole);
%}

### Switch to Tenant 3
POST {{baseUrl}}/auth/switch-tenant
Authorization: Bearer {{selectionAccessToken}}
Content-Type: application/json

{
  "tenantId": {{tenantId3}}
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.global.set("tenant3AccessToken", response.body.accessToken);
    client.log("✓ Switched to Tenant 3 (Global Solutions)");
    client.log("  - Current Tenant ID: " + response.body.currentTenantId);
    client.log("  - Current Role: " + response.body.currentRole);
    client.log("  - NOTE: Role is 'user' in this tenant (not admin)");
%}

