### ========================================
### 10. REMOVE USER FROM TENANT
### ========================================

### Remove Demo User from Tenant 3
DELETE {{baseUrl}}/admin/tenants/{{tenantId3}}/users/1
Authorization: Bearer {{adminAccessToken}}

> {%
    client.test("Status is 204", function() {
        client.assert(response.status === 204, "Expected 204");
    });
    client.log("✓ Removed demo user from Tenant 3");
%}

### Verify Removal - List Users in Tenant 3
GET {{baseUrl}}/admin/tenants/{{tenantId3}}/users
Authorization: Bearer {{adminAccessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.log("✓ Users in Tenant 3 after removal:");
    if (response.body.length === 0) {
        client.log("  - (empty)");
    } else {
        response.body.forEach(u => {
            client.log("  - User ID: " + u.userId);
        });
    }
%}

