### ========================================
### 3. LIST ALL TENANTS
### ========================================

### Get All Tenants
GET {{baseUrl}}/admin/tenants?page=0&size=50
Authorization: Bearer {{adminAccessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Is array", function() {
        client.assert(Array.isArray(response.body), "Response should be array");
    });
    client.log("✓ Retrieved all tenants: " + response.body.length + " tenants found");
    response.body.forEach((t, idx) => {
        client.log("  [" + (idx + 1) + "] " + t.name + " (ID: " + t.id + ")");
    });
%}

