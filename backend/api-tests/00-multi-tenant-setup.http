### ========================================
### 4. ADD DEMO USER TO MULTIPLE TENANTS
### ========================================

### Add Demo User to Tenant 1 (Acme Corp) as admin
POST {{baseUrl}}/admin/tenants/{{tenantId1}}/users
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "email": "{{demoEmail}}",
  "role": "admin"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has membership id", function() {
        client.assert(response.body.id !== undefined, "Response should have id");
    });
    client.global.set("membership1Id", response.body.id);
    client.log("✓ Added demo user to Tenant 1 (Acme Corp) as admin");
    client.log("  - Membership ID: " + response.body.id);
    client.log("  - Role: " + response.body.role);
    client.log("  - Status: " + response.body.status);
%}

### Add Demo User to Tenant 2 (TechStart Inc) as admin
