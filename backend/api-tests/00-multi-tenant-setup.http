### ===============================================
### MULTI-TENANT SETUP - Create Tenants & Memberships
### ===============================================
### This file demonstrates:
### 1. Creating multiple tenants
### 2. Adding users to multiple tenants
### 3. Testing tenant selection on login (when user has multiple tenants)
### 4. Testing tenant switching

### Prerequisites:
### - Run auth.http first to get accessToken for system_admin
### - Ensure demo user exists in database

---

### ========================================
### 1. LOGIN AS SYSTEM ADMIN (demo user)
### ========================================

### Login - System Admin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{demoEmail}}",
  "password": "{{demoPassword}}"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
    });
    client.test("Has accessToken", function() {
        client.assert(response.body.accessToken !== undefined, "Response should have accessToken");
    });
    client.global.set("adminAccessToken", response.body.accessToken);
    client.global.set("adminRefreshToken", response.body.refreshToken);
    client.global.set("adminTenantId", response.body.currentTenantId);
    client.log("✓ Logged in as system admin");
    client.log("  - Access Token: " + response.body.accessToken.substring(0, 20) + "...");
    client.log("  - Current Tenant ID: " + response.body.currentTenantId);
%}

---

### ========================================
### 2. CREATE NEW TENANTS
### ========================================

### Create Tenant 1 - Acme Corp
POST {{baseUrl}}/admin/tenants
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "name": "Acme Corporation"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has tenant id", function() {
        client.assert(response.body.id !== undefined, "Response should have id");
    });
    client.global.set("tenantId1", response.body.id);
    client.log("✓ Created Tenant 1 (Acme Corporation): ID " + response.body.id);
%}

