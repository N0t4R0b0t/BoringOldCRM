### ====================================
### NABISCO THEMED BULK SAMPLE DATA - API Tests
### ====================================

# 1. Create Nabisco-Themed Custom Fields
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Customer",
  "key": "brand",
  "label": "Brand",
  "type": "text",
  "required": true,
  "config": { "maxLength": 50, "placeholder": "e.g. Oreo, Ritz" }
}

###
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Customer",
  "key": "region",
  "label": "Region",
  "type": "text",
  "required": false,
  "config": { "maxLength": 50, "placeholder": "e.g. North America" }
}

###
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Contact",
  "key": "favorite_snack",
  "label": "Favorite Snack",
  "type": "text",
  "required": false,
  "config": { "maxLength": 50, "placeholder": "e.g. Chips Ahoy!" }
}

###
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Opportunity",
  "key": "product_line",
  "label": "Product Line",
  "type": "text",
  "required": true,
  "config": { "maxLength": 50, "placeholder": "e.g. Crackers" }
}

###
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Activity",
  "key": "distributor",
  "label": "Distributor",
  "type": "text",
  "required": false,
  "config": { "maxLength": 50, "placeholder": "e.g. Sysco" }
}

# 2. Bulk Create Customers (30+)
# Example brands: Oreo, Ritz, Chips Ahoy!, Wheat Thins, Triscuit, Belvita, Teddy Grahams, Premium, Good Thins, Barnum's Animals
# Example regions: North America, Europe, Asia, Latin America, Middle East, Africa

# Customers
### Nabisco Customers (30+)
# Each customer will have a unique name, brand, and region
POST {{baseUrl}}/customers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Nabisco HQ",
  "status": "active",
  "customFields": { "brand": "Oreo", "region": "North America" }
}

