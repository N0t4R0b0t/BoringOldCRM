### 13. List Activities - Sorted by Due Date
GET {{baseUrl}}/activities?sortBy=dueAt&sortOrder=asc
Authorization: Bearer {{accessToken}}

> {%
    client.test("Results are sorted", function() {
        if (response.body.content.length > 1) {
            const first = new Date(response.body.content[0].dueAt);
            const second = new Date(response.body.content[1].dueAt);
            client.assert(first <= second, "Should be sorted by due date ascending");
        }
    });
    client.log("✓ Activities sorted by dueAt ASC");
%}

