### 40. Activity Metrics - Get Activity Summary
GET {{baseUrl}}/activities
Authorization: Bearer {{accessToken}}

> {%
    if (response.status === 200) {
        let byType = {};
        let byStatus = {};
        response.body.content.forEach(activity => {
            byType[activity.type] = (byType[activity.type] || 0) + 1;
            byStatus[activity.status] = (byStatus[activity.status] || 0) + 1;
        });
        client.log("✓ Activity Metrics:");
        client.log("  Total Activities: " + response.body.totalElements);
        client.log("  By Type: " + JSON.stringify(byType, null, 2));
        client.log("  By Status: " + JSON.stringify(byStatus, null, 2));
    }
%}

