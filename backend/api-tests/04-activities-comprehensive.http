### 10. Get Activity by ID
GET {{baseUrl}}/activities/{{activityId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Activity subject matches", function() {
        client.assert(response.body.subject === "Discovery Call", "Subject should match");
    });
    client.test("Activity type matches", function() {
        client.assert(response.body.type === "call", "Type should match");
    });
    client.log("✓ Retrieved activity: " + response.body.subject);
%}

