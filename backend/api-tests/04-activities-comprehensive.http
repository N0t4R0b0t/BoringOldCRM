### 27. Update Activity - Change Subject and Description
PUT {{baseUrl}}/activities/{{activityId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "subject": "Discovery Call - Follow Up",
  "description": "Follow up on initial discovery call, discuss next steps"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Subject was updated", function() {
        client.assert(response.body.subject === "Discovery Call - Follow Up", "Subject should be updated");
    });
    client.log("✓ Updated activity subject and description");
%}

### 28. Update Activity - Reschedule Due Date
PUT {{baseUrl}}/activities/{{activityId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "dueAt": "2026-03-17T14:00:00Z"
}

> {%
    client.test("Due date was updated", function() {
        // Check if dueAt contains the expected date (allows for format differences)
        const dueAt = response.body.dueAt;
        client.assert(dueAt && dueAt.includes("2026-03-17") && dueAt.includes("14:00"),
            "Due date should contain 2026-03-17 and 14:00, got: " + dueAt);
    });
    client.log("✓ Rescheduled activity to " + response.body.dueAt);
%}

