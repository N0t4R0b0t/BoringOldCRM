### 42. Get Overdue Activities - Past Due Date with Status Not Completed
# Note: This would require date filtering in the API if supported
GET {{baseUrl}}/activities?status=pending,scheduled,in_progress&sortBy=dueAt&sortOrder=asc
Authorization: Bearer {{accessToken}}

> {%
    if (response.status === 200) {
        const now = new Date();
        const overdue = response.body.content.filter(a => {
            const dueDate = new Date(a.dueAt);
            return dueDate < now && a.status !== 'completed' && a.status !== 'cancelled';
        });
        client.log("✓ Potentially overdue activities: " + overdue.length);
    }
%}
