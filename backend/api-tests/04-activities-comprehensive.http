### ====================================
### ACTIVITIES - Comprehensive API Tests
### ====================================
### Prerequisites: Run customers tests first to get customerId

### 0. Ensure we have a customerId
GET {{baseUrl}}/customers?page=0&size=1
Authorization: Bearer {{accessToken}}

> {%
    if (!client.global.get("customerId") && response.body.content && response.body.content.length > 0) {
        client.global.set("customerId", response.body.content[0].id);
        client.log("✓ Auto-captured customerId: " + response.body.content[0].id);
    }
%}

### 1. Create Activity - Call Type
POST {{baseUrl}}/activities
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "subject": "Discovery Call",
  "type": "call",
  "dueAt": "2026-03-15T10:00:00Z",
  "description": "Initial discovery call to understand customer needs",
  "relatedType": "customer",
  "relatedId": {{customerId}},
  "status": "scheduled"
}

> {%
    client.test("Status is 201", function() {
        client.assert(response.status === 201, "Expected 201");
    });
    client.test("Response has id", function() {
        client.assert(response.body.id !== undefined, "Response should have id");
    });
    client.global.set("activityId", response.body.id);
    client.log("✓ Created call activity with ID: " + response.body.id);
%}

