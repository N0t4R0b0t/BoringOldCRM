> {%
    client.log("✓ Activities sorted by createdAt DESC");
%}

### 15. Search Activities - By Subject
GET {{baseUrl}}/activities?search=Call
Authorization: Bearer {{accessToken}}

> {%
    client.test("Search results contain keyword", function() {
        if (response.body.content.length > 0) {
            const hasKeyword = response.body.content.some(a =>
                a.subject.toLowerCase().includes("call")
            );
            client.assert(hasKeyword, "Results should contain 'call'");
        }
    });
    client.log("✓ Search by 'Call': " + response.body.content.length + " results");
%}

