### Tenant 1 - Create Calculated Field: Engagement Score
POST {{baseUrl}}/calculated-fields
Authorization: Bearer {{tenant1AccessToken}}
Content-Type: application/json

{
  "entityType": "Customer",
  "key": "engagement_score",
  "label": "Engagement Score",
  "expression": "T(java.lang.Math).min(100, (company_size / 100) + (growth_rate / 2))",
  "returnType": "number"
}

> {%
    client.log("✓ Tenant 1: Created 'Engagement Score' calculated field");
%}

### Tenant 1 - Create Calculated Field: Deal Progression
POST {{baseUrl}}/calculated-fields
Authorization: Bearer {{tenant1AccessToken}}
Content-Type: application/json

{
  "entityType": "Opportunity",
  "key": "deal_progression",
  "label": "Deal Progression (%)",
  "expression": "customField_sales_stage != null ? (customField_sales_stage.currentIndex + 1) * 20 : 0",
  "returnType": "number"
}

> {%
    client.log("✓ Tenant 1: Created 'Deal Progression' calculated field");
%}

### Tenant 1 - Create Policy: Block high-value customer archival
POST {{baseUrl}}/policy-rules/definitions
Authorization: Bearer {{tenant1AccessToken}}
Content-Type: application/json

{
  "name": "Prevent Archiving High-Value Customers",
  "entityType": "Customer",
  "operations": "UPDATE",
  "expression": "entity.customFields.annual_revenue > 10000000 && entity.status == 'archived'",
  "severity": "DENY",
  "description": "Prevents accidental archival of customers with annual revenue exceeding $10M"
}

> {%
    client.log("✓ Tenant 1: Created policy - Block high-value customer archival");
%}

### Tenant 1 - Create Policy: Warn on critical risk customer update
POST {{baseUrl}}/policy-rules/definitions
Authorization: Bearer {{tenant1AccessToken}}
Content-Type: application/json

{
  "name": "Warn on Critical Risk Updates",
  "entityType": "Customer",
  "operations": "UPDATE",
  "expression": "entity.customFields.risk_level == 'Critical'",
  "severity": "WARN",
  "description": "Requires confirmation when modifying critical-risk customers"
}

> {%
    client.log("✓ Tenant 1: Created policy - Warn on critical risk updates");
%}

### Tenant 1 - Create Policy: Block opportunity stage regression
POST {{baseUrl}}/policy-rules/definitions
Authorization: Bearer {{tenant1AccessToken}}
Content-Type: application/json

{
  "name": "Block Deal Stage Regression",
  "entityType": "Opportunity",
  "operations": "UPDATE",
  "expression": "previous.customFields.sales_stage.currentIndex > entity.customFields.sales_stage.currentIndex && previous.customFields.sales_stage.currentIndex >= 3",
  "severity": "DENY",
  "description": "Prevents moving deals backwards from negotiation or closed stages"
}

> {%
    client.log("✓ Tenant 1: Created policy - Block deal stage regression");
%}

