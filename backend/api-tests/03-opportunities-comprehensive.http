### 12. List Opportunities - Sorted by Value (DESC)
GET {{baseUrl}}/opportunities?sortBy=value&sortOrder=desc
Authorization: Bearer {{accessToken}}

> {%
    client.test("Results are sorted by value", function() {
        if (response.body.content.length > 1) {
            // Filter out null values for comparison
            const withValues = response.body.content.filter(o => o.value !== null && o.value !== undefined);
            if (withValues.length > 1) {
                client.assert(
                    withValues[0].value >= withValues[1].value,
                    "Should be sorted by value descending"
                );
            }
        }
    });
    client.log("✓ Opportunities sorted by value DESC");
%}

