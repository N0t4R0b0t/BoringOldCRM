### 37. Pipeline Value Calculation - Get All Open Opportunities
GET {{baseUrl}}/opportunities?stage=prospecting,discovery,proposal,negotiation
Authorization: Bearer {{accessToken}}

> {%
    if (response.status === 200) {
        let totalValue = 0;
        let weightedValue = 0;
        response.body.content.forEach(opp => {
            totalValue += opp.value || 0;
            weightedValue += (opp.value || 0) * ((opp.probability || 0) / 100);
        });
        client.log("✓ Pipeline Analysis:");
        client.log("  Total Pipeline Value: $" + totalValue.toLocaleString());
        client.log("  Weighted Pipeline Value: $" + weightedValue.toLocaleString());
        client.log("  Number of Opportunities: " + response.body.content.length);
    }
%}
