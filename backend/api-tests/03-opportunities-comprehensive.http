### 9. Get Opportunity by ID
GET {{baseUrl}}/opportunities/{{opportunityId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Opportunity name matches", function() {
        client.assert(response.body.name === "Enterprise Software Deal", "Name should match");
    });
    client.test("Has value and stage", function() {
        client.assert(response.body.value === 100000.00, "Value should match");
        client.assert(response.body.stage === "prospecting", "Stage should match");
    });
    client.log("✓ Retrieved opportunity: " + response.body.name);
%}

