### 14. Search Opportunities - By Name
GET {{baseUrl}}/opportunities?search=Enterprise
Authorization: Bearer {{accessToken}}

> {%
    client.test("Search results contain keyword", function() {
        if (response.body.content.length > 0) {
            const hasKeyword = response.body.content.some(o =>
                o.name.toLowerCase().includes("enterprise")
            );
            client.assert(hasKeyword, "Results should contain 'enterprise'");
        }
    });
    client.log("✓ Search by 'Enterprise': " + response.body.content.length + " results");
%}

