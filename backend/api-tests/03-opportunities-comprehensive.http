### 21. Filter Opportunities - By Customer ID
GET {{baseUrl}}/opportunities?customerId={{customerId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("All results belong to customer", function() {
        const allMatch = response.body.content.every(o => o.customerId == client.global.get("customerId"));
        client.assert(allMatch, "All opportunities should belong to customer");
    });
    client.log("✓ Filtered by customerId: " + response.body.content.length + " opportunities");
%}

