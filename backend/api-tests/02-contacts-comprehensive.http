### 21. Get Contact - Verify Updates
GET {{baseUrl}}/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Updates persisted", function() {
        client.assert(response.body.phone === "+1-555-9999", "Phone update should persist");
        client.assert(response.body.customFields !== null, "Custom fields should persist");
    });
