POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "Bob Johnson"
}

> {%
    client.global.set("contactId3", response.body.id);
    client.log("✓ Created minimal contact, ID: " + response.body.id);
