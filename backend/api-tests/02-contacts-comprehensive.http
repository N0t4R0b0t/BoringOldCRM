### ====================================
### CONTACTS - Comprehensive API Tests
### ====================================
### Prerequisites: Run customers tests first to get customerId

### 0. Ensure we have a customerId
GET {{baseUrl}}/customers?page=0&size=1
Authorization: Bearer {{accessToken}}

> {%
    if (!client.global.get("customerId") && response.body.content && response.body.content.length > 0) {
        client.global.set("customerId", response.body.content[0].id);
        client.log("✓ Auto-captured customerId: " + response.body.content[0].id);
    }
%}

### 1. Create Contact - Basic
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "John Doe",
  "email": "john.doe@acme.com",
  "phone": "+1-555-0100",
  "title": "CTO"
}

> {%
    client.test("Status is 201", function() {
        client.assert(response.status === 201, "Expected 201");
    });
    client.test("Response has id", function() {
        client.assert(response.body.id !== undefined, "Response should have id");
    });
    client.global.set("contactId", response.body.id);
    client.log("✓ Created contact with ID: " + response.body.id);
%}

### 2. Create Contact - With All Fields
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "Jane Smith",
  "email": "jane.smith@acme.com",
  "phone": "+1-555-0101",
  "title": "CEO",
  "customFields": {
    "linkedIn": "https://linkedin.com/in/janesmith",
    "preferredContact": "email",
    "timezone": "EST"
  }
}

> {%
    client.global.set("contactId2", response.body.id);
    client.log("✓ Created contact with all fields, ID: " + response.body.id);
%}

