### 4. Create Contact - Without Email
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "Alice Brown",
  "phone": "+1-555-0102",
  "title": "Manager"
}

> {%
    client.global.set("noEmailContactId", response.body.id);
    client.log("✓ Created contact without email, ID: " + response.body.id);
%}

### 5. Get Contact by ID
GET {{baseUrl}}/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Contact name matches", function() {
        client.assert(response.body.name === "John Doe", "Name should match");
    });
    client.test("Customer association exists", function() {
        client.assert(response.body.customerId !== undefined, "Should have customerId");
    });
    client.log("✓ Retrieved contact: " + response.body.name);
%}

### 6. List All Contacts - Default Pagination
GET {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has content array", function() {
        client.assert(Array.isArray(response.body.content), "Content should be array");
    });
    client.test("Has pagination info", function() {
        client.assert(response.body.totalElements !== undefined, "Should have totalElements");
    });
    client.log("✓ Listed contacts, total: " + response.body.totalElements);
%}

### 7. List Contacts - With Pagination
GET {{baseUrl}}/contacts?page=0&size=3
Authorization: Bearer {{accessToken}}

> {%
    client.test("Page size is respected", function() {
        client.assert(response.body.pageSize === 3, "Page size should be 3");
    });
    client.log("✓ Paginated list, size: " + response.body.content.length);
%}

### 8. List Contacts - Sorted by Name
GET {{baseUrl}}/contacts?sortBy=name&sortOrder=asc
Authorization: Bearer {{accessToken}}

> {%
    client.test("Results are sorted", function() {
        if (response.body.content.length > 1) {
            client.assert(
                response.body.content[0].name <= response.body.content[1].name,
                "Should be sorted ascending"
            );
        }
    });
    client.log("✓ Contacts sorted by name ASC");
%}

### 9. List Contacts - Sorted by Created Date
GET {{baseUrl}}/contacts?sortBy=createdAt&sortOrder=desc
Authorization: Bearer {{accessToken}}

> {%
    client.log("✓ Contacts sorted by createdAt DESC");
%}

### 10. Search Contacts - By Name
GET {{baseUrl}}/contacts?search=John
Authorization: Bearer {{accessToken}}

> {%
    client.test("Search results contain keyword", function() {
        if (response.body.content.length > 0) {
            const hasKeyword = response.body.content.some(c =>
                c.name.toLowerCase().includes("john")
            );
            client.assert(hasKeyword, "Results should contain 'john'");
        }
    });
    client.log("✓ Search by 'John': " + response.body.content.length + " results");
%}

### 11. Search Contacts - By Email
GET {{baseUrl}}/contacts?search=jane.smith
Authorization: Bearer {{accessToken}}

> {%
    client.log("✓ Search by email: " + response.body.content.length + " results");
%}

### 12. Filter Contacts - By Customer ID
GET {{baseUrl}}/contacts?customerId={{customerId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("All results belong to customer", function() {
        const allMatch = response.body.content.every(c => c.customerId == client.global.get("customerId"));
        client.assert(allMatch, "All contacts should belong to customer");
    });
    client.log("✓ Filtered by customerId: " + response.body.content.length + " contacts");
%}

### 13. Filter Contacts - With Email Only
GET {{baseUrl}}/contacts?hasEmail=true
Authorization: Bearer {{accessToken}}

> {%
    client.test("All results have email", function() {
        const allHaveEmail = response.body.content.every(c => c.email !== null && c.email !== "");
        client.assert(allHaveEmail, "All contacts should have email");
    });
    client.log("✓ Filtered contacts with email: " + response.body.content.length);
%}

### 14. Filter Contacts - Without Email
GET {{baseUrl}}/contacts?hasEmail=false
Authorization: Bearer {{accessToken}}

> {%
    client.test("Results have no email", function() {
        const noneHaveEmail = response.body.content.every(c => c.email === null || c.email === "");
        client.assert(noneHaveEmail, "Contacts should not have email");
    });
    client.log("✓ Filtered contacts without email: " + response.body.content.length);
%}

### 15. Combined Filters - Customer + Email + Search
GET {{baseUrl}}/contacts?customerId={{customerId}}&hasEmail=true&search=doe
Authorization: Bearer {{accessToken}}

> {%
    client.log("✓ Combined filters applied: " + response.body.content.length + " results");
%}

### 16. Update Contact - Basic Fields
PUT {{baseUrl}}/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "John Michael Doe",
  "email": "john.m.doe@acme.com",
  "title": "Chief Technology Officer"
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Name was updated", function() {
        client.assert(response.body.name === "John Michael Doe", "Name should be updated");
    });
    client.log("✓ Updated contact name and title");
%}

### 17. Update Contact - Change Phone
PUT {{baseUrl}}/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "+1-555-9999"
}

> {%
    client.test("Phone was updated", function() {
        client.assert(response.body.phone === "+1-555-9999", "Phone should be updated");
    });
    client.log("✓ Updated contact phone");
%}

