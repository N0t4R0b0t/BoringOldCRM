### 27. Error Test - Invalid Email Format
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "Invalid Email Test",
  "email": "not-an-email"
}

> {%
    client.test("Should handle invalid email", function() {
        // May return 400 or create successfully depending on validation
        client.assert(response.status === 400 || response.status === 201, "Should handle invalid email");
    });
    client.log("✓ Invalid email handled: status " + response.status);
%}

### 28. Edge Case - Very Long Name
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "This Is A Very Long Name That Goes On And On And Might Exceed Some Database Limits If Not Properly Validated",
  "email": "longname@test.com"
}

> {%
    client.log("✓ Long name test: status " + response.status);
%}

### 29. Edge Case - Special Characters in Name
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "name": "François O'Brien-Smith Jr.",
  "email": "special@test.com"
}

> {%
    client.test("Special characters accepted", function() {
        client.assert(response.status === 201, "Should accept special characters");
    });
    client.log("✓ Special characters in name handled");
%}

### 30. Cleanup - Note: Contacts usually don't have DELETE endpoint
