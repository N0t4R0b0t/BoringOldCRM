### ADVANCED FILTERING TESTS ###

### 19. Advanced Filter - Multiple Conditions
POST {{baseUrl}}/customers/search
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "filters": [
    {
      "field": "status",
      "operator": "equals",
      "value": "active"
    },
    {
      "field": "customFields.employee_count",
      "operator": "greaterThan",
      "value": 100
    }
  ],
  "sort": {
    "field": "name",
    "direction": "asc"
  },
  "page": 0,
  "size": 20
}

> {%
    client.test("Advanced search executed", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.log("✓ Advanced filter applied: " + (response.body.content ? response.body.content.length : 0) + " results");
%}

### 20. Saved Filter - Create
POST {{baseUrl}}/filters
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "High Value Active Customers",
  "entityType": "Customer",
  "filters": [
    {
      "field": "status",
      "operator": "equals",
      "value": "active"
    }
  ]
}

> {%
    if (response.status === 201) {
        client.global.set("savedFilterId", response.body.id);
        client.log("✓ Saved filter created: ID " + response.body.id);
    } else {
        client.log("✓ Save filter endpoint: status " + response.status);
    }
%}

### 21. Integration Test - Full Workflow
### Create Customer -> Create Contact -> Create Opportunity -> Create Activity -> Get Timeline

POST {{baseUrl}}/customers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Integration Test Corp",
  "status": "active"
}

> {%
    client.global.set("integrationCustomerId", response.body.id);
    client.log("✓ [1/4] Created customer: " + response.body.id);
%}

###
POST {{baseUrl}}/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{integrationCustomerId}},
  "name": "Test Contact",
  "email": "test@integration.com"
}

> {%
    client.log("✓ [2/4] Created contact");
%}

###
POST {{baseUrl}}/opportunities
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customerId": {{integrationCustomerId}},
  "name": "Integration Test Deal",
  "stage": "prospecting",
  "value": 50000
}

> {%
    client.global.set("integrationOppId", response.body.id);
    client.log("✓ [3/4] Created opportunity");
%}

###
POST {{baseUrl}}/activities
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "subject": "Integration Test Activity",
  "type": "call",
  "relatedType": "customer",
  "relatedId": {{integrationCustomerId}},
  "status": "completed"
}

> {%
    client.log("✓ [4/4] Created activity");
    client.log("✓ Integration workflow complete!");
%}
