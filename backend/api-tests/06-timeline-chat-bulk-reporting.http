### ====================================
### TIMELINE, CHAT, BULK OPS, REPORTING - API Tests
### ====================================

### TIMELINE TESTS ###

### 1. Get Customer Timeline
GET {{baseUrl}}/timeline/Customer/{{customerId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Timeline is array", function() {
        client.assert(Array.isArray(response.body), "Timeline should be array");
    });
    client.log("✓ Retrieved customer timeline: " + response.body.length + " events");
%}

### 2. Get Opportunity Timeline
GET {{baseUrl}}/timeline/Opportunity/{{opportunityId}}
Authorization: Bearer {{accessToken}}

> {%
    client.log("✓ Retrieved opportunity timeline: " + response.body.length + " events");
%}

### CHAT TESTS ###

### 3. Get Customer Chat History
GET {{baseUrl}}/chat/Customer/{{customerId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.log("✓ Retrieved chat history: " + response.body.length + " messages");
%}

### 4. Send Chat Message
POST {{baseUrl}}/chat/Customer/{{customerId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "message": "Following up on our meeting today",
  "internal": false
}

> {%
    client.test("Message sent", function() {
        client.assert(response.status === 201, "Expected 201");
    });
    client.log("✓ Sent chat message");
%}

### 5. Send Internal Note
POST {{baseUrl}}/chat/Customer/{{customerId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "message": "Internal note: Customer seems very interested in enterprise plan",
  "internal": true
}

> {%
    client.log("✓ Sent internal note");
%}

### BULK OPERATIONS TESTS ###

### 6. Bulk Update - Customer Status
POST {{baseUrl}}/bulk/customers/update
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "ids": [{{customerId}}],
  "updates": {
    "status": "active"
  }
}

> {%
    client.test("Bulk update successful", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.log("✓ Bulk updated customers");
%}

### 7. Bulk Update - Opportunity Stage
POST {{baseUrl}}/bulk/opportunities/update
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "ids": [{{opportunityId}}, {{opportunityId2}}],
  "updates": {
    "stage": "proposal"
  }
}

> {%
    client.log("✓ Bulk updated opportunities");
%}

### 8. Bulk Delete - Activities (if supported)
POST {{baseUrl}}/bulk/activities/delete
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "ids": [{{activityId}}]
}

> {%
    client.test("Bulk delete executed", function() {
        client.assert(response.status === 200 || response.status === 204, "Expected successful response");
    });
    client.log("✓ Bulk deleted activities: status " + response.status);
%}

### REPORTING TESTS ###

### 9. Get Sales Report - Overview
GET {{baseUrl}}/reports/sales/overview
Authorization: Bearer {{accessToken}}

> {%
    client.test("Report generated", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has metrics", function() {
        client.assert(response.body.totalRevenue !== undefined || response.body.metrics !== undefined, "Should have metrics");
    });
    client.log("✓ Sales overview report generated");
%}

