### ====================================
### CUSTOM FIELD DEFINITIONS - API Tests
### ====================================

### 1. Create Text Custom Field for Customer
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Customer",
  "key": "industry",
  "label": "Industry",
  "type": "text",
  "required": true,
  "config": {
    "maxLength": 100,
    "placeholder": "Enter industry"
  }
}

> {%
    client.test("Status is 201", function() {
        client.assert(response.status === 201, "Expected 201");
    });
    client.global.set("customerFieldId", response.body.id);
    client.log("✓ Created text custom field, ID: " + response.body.id);
%}

### 2. Create Number Custom Field for Customer
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Customer",
  "key": "employee_count",
  "label": "Number of Employees",
  "type": "number",
  "required": false,
  "config": {
    "min": 1,
    "max": 1000000
  }
}

> {%
    client.log("✓ Created number custom field");
%}

### 3. Create Select Custom Field for Opportunity
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Opportunity",
  "key": "lead_source",
  "label": "Lead Source",
  "type": "select",
  "required": true,
  "config": {
    "options": ["Website", "Referral", "Conference", "Cold Call", "Social Media"]
  }
}

> {%
    client.global.set("oppFieldId", response.body.id);
    client.log("✓ Created select custom field");
%}

