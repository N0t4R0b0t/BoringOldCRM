### 10. Update Custom Field - Change Label
PUT {{baseUrl}}/custom-fields/{{customerFieldId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "label": "Industry Sector",
  "required": false
}

> {%
    client.test("Label was updated", function() {
        client.assert(response.body.label === "Industry Sector", "Label should be updated");
    });
    client.log("✓ Updated custom field label");
%}

### 11. Update Custom Field - Change Config
PUT {{baseUrl}}/custom-fields/{{oppFieldId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "config": {
    "options": ["Website", "Referral", "Conference", "Cold Call", "Social Media", "Partner"]
  }
}

> {%
    client.log("✓ Updated custom field config");
%}

### 12. Delete Custom Field
DELETE {{baseUrl}}/custom-fields/{{customerFieldId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 204", function() {
        client.assert(response.status === 204, "Expected 204");
    });
    client.log("✓ Deleted custom field");
%}

### 13. Error Test - Duplicate Key
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "Opportunity",
  "key": "lead_source",
  "label": "Lead Source Duplicate",
  "type": "text",
  "required": false,
  "config": {}
}

> {%
    client.test("Should reject duplicate key", function() {
        client.assert(response.status === 400 || response.status === 409, "Expected validation error");
    });
    client.log("✓ Duplicate key handled: status " + response.status);
%}

### 14. Error Test - Invalid Entity Type
POST {{baseUrl}}/custom-fields
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "entityType": "InvalidEntity",
  "key": "test_field",
  "label": "Test Field",
  "type": "text",
  "required": false,
  "config": {}
}

> {%
    client.test("Should reject invalid entity type", function() {
        client.assert(response.status === 400, "Expected validation error");
    });
    client.log("✓ Invalid entity type handled: status " + response.status);
%}

### 15. Test Customer with Custom Field
POST {{baseUrl}}/customers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Test Company with Custom Fields",
  "status": "active",
  "customFields": {
    "employee_count": 500
  }
}

> {%
    client.test("Custom field accepted", function() {
        client.assert(response.status === 201, "Should create customer with custom field");
    });
    client.log("✓ Created customer with custom field data");
%}
