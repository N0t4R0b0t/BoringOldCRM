### 6. List Custom Fields for Customer
GET {{baseUrl}}/custom-fields?entityType=Customer
Authorization: Bearer {{accessToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200");
    });
    client.test("Has array response", function() {
        client.assert(Array.isArray(response.body), "Should return array");
    });
    client.log("✓ Listed Customer custom fields: " + response.body.length);
%}

