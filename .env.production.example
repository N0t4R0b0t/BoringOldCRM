# ── Required ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters

DB_PASSWORD=change-me
RABBITMQ_PASSWORD=change-me
REDIS_PASSWORD=change-me

# ── AI providers (at least one required for the assistant) ────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Web search in the assistant (free key at https://tavily.com)
TAVILY_API_KEY=

# Port to expose on the host (default 80)
HTTP_PORT=80
